# HpcConnect configuration example.
# used as a fallback when no .env file is present.

# Your HPC account username (e.g. as issued by FAU/NHR registration)
HPC_CONNECT_USERNAME=your_username

# SSH alias or hostname to connect to (see README for available clusters)
HPC_CONNECT_SSH_ALIAS=alex

# Path to your SSH private key (identity file)
HPC_CONNECT_IDENTITY_FILE=~/.ssh/id_hpc

# Login/proxy node used as a jump host for the target cluster
HPC_CONNECT_PROXY_JUMP=csnhr.nhr.fau.de

# Remote path to your vault directory (high-capacity storage for models)
HPC_CONNECT_VAULT_DIR=$HOME/vault/hpc_connect

# Remote path to your work/cache directory (fast disk for scripts and cache)
HPC_CONNECT_WORK_DIR=$HOME/.cache/hpc_connect

# Port range for local port forwarding
HPC_CONNECT_PORT_RANGE=8000:8999

# HuggingFace Hub API token – required for gated/private model downloads.
# Get yours at https://huggingface.co/settings/tokens
HUGGINGFACE_HUB_TOKEN=hf_your_token_here

